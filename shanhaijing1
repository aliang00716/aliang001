// 计算整体范围
let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
const allMountains = [];
seriesData.forEach(s => {
  s.mountains.forEach(m => {
    allMountains.push({...m, seriesId: s.id, seriesName: s.name, seriesColor: s.color, seriesColorLight: s.colorLight});
    if (m.x < minX) minX = m.x;
    if (m.y < minY) minY = m.y;
    if (m.x > maxX) maxX = m.x;
    if (m.y > maxY) maxY = m.y;
  });
});
const PAD = 60;
minX -= PAD; minY -= PAD;
maxX += PAD; maxY += PAD;
const MAP_W = maxX - minX;
const MAP_H = maxY - minY;

// ============= SVG 渲染 =============
const svg = document.getElementById('map-svg');
const mapWrap = document.getElementById('map-wrap');
const tooltip = document.getElementById('tooltip');
const detailPanel = document.getElementById('detail-panel');
const zoomLabel = document.getElementById('zoom-label');
const scaleBarBar = document.getElementById('scale-bar-bar');
const scaleBarLabel = document.getElementById('scale-bar-label');
const coordIndicator = document.getElementById('coord-indicator');

let currentZoom = 1;
let currentMountain = null;

function buildSVG(zoom) {
  const w = MAP_W * zoom;
  const h = MAP_H * zoom;
  svg.setAttribute('width', w);
  svg.setAttribute('height', h);
  svg.setAttribute('viewBox', `${minX} ${minY} ${MAP_W} ${MAP_H}`);
  svg.style.width = w + 'px';
  svg.style.height = h + 'px';

  let html = '';

  // 网格线 (每500里)
  const gridStep = 500;
  for (let gx = Math.floor(minX / gridStep) * gridStep; gx <= maxX; gx += gridStep) {
    html += `<line class="grid-line" x1="${gx}" y1="${minY}" x2="${gx}" y2="${maxY}"/>`;
  }
  for (let gy = Math.floor(minY / gridStep) * gridStep; gy <= maxY; gy += gridStep) {
    html += `<line class="grid-line" x1="${minX}" y1="${gy}" x2="${maxX}" y2="${gy}"/>`;
  }
  // 网格标签
  for (let gx = Math.floor(minX / gridStep) * gridStep; gx <= maxX; gx += gridStep) {
    if (gx === 0) continue;
    html += `<text class="grid-label" x="${gx}" y="${minY + PAD/3}" text-anchor="middle">${gx}里</text>`;
    html += `<text class="grid-label" x="${gx}" y="${maxY - 5}" text-anchor="middle">${gx}里</text>`;
  }
  for (let gy = Math.floor(minY / gridStep) * gridStep; gy <= maxY; gy += gridStep) {
    if (gy === 0) continue;
    html += `<text class="grid-label" x="${minX + 5}" y="${gy + 4}">${gy}里</text>`;
  }

  // 方向指示 (东北角指南针)
  const compassX = minX + 20;
  const compassY = minY + 20;
  html += `<g transform="translate(${compassX},${compassY})">
    <circle cx="0" cy="0" r="14" fill="rgba(255,255,255,0.8)" stroke="#a09080"/>
    <line x1="0" y1="-10" x2="0" y2="10" stroke="#c92a2a" stroke-width="1.5"/>
    <line x1="-10" y1="0" x2="10" y2="0" stroke="#2c1a0e" stroke-width="1.5"/>
    <polygon points="0,-12 -3,-4 3,-4" fill="#c92a2a"/>
    <text x="0" y="-15" text-anchor="middle" font-size="10" fill="#c92a2a" font-family="SimSun">北</text>
    <text x="14" y="1" font-size="10" fill="#2c1a0e" font-family="SimSun">东</text>
  </g>`;

  // 连线
  seriesData.forEach(s => {
    const ms = s.mountains;
    let pathD = '';
    for (let i = 0; i < ms.length; i++) {
      if (i === 0) pathD += `M ${ms[i].x} ${ms[i].y}`;
      else pathD += ` L ${ms[i].x} ${ms[i].y}`;
    }
    html += `<path class="path-line" d="${pathD}" stroke="${s.color}" stroke-width="2.5" opacity="0.6" fill="none"/>`;

    // 距离标注 (在每段中间)
    for (let i = 1; i < ms.length; i++) {
      const mx = (ms[i-1].x + ms[i].x) / 2;
      const my = (ms[i-1].y + ms[i].y) / 2;
      const dx = ms[i].x - ms[i-1].x;
      const dy = ms[i].y - ms[i-1].y;
      const dist = ms[i].distance;
      const angle = Math.atan2(dy, dx) * 180 / Math.PI;

      // 背景
      const labelW = dist >= 100 ? 56 : 46;
      html += `<rect class="dist-bg" x="${mx - labelW/2}" y="${my - 9}" width="${labelW}" height="16" rx="3"/>`;
      html += `<text class="dist-label" x="${mx}" y="${my + 3}" text-anchor="middle" fill="${s.color}" transform="rotate(${angle},${mx},${my})">${ms[i].direction_label || ms[i].direction + dist + '里'}</text>`;
    }
  });

  // 山峰标记
  allMountains.forEach(m => {
    const sz = m.isFirst ? 10 : 7;
    const shape = m.isFirst
      ? `<polygon points="${m.x-sz},${m.y+sz*0.6} ${m.x+sz},${m.y+sz*0.6} ${m.x},${m.y-sz*1.2}" fill="${m.seriesColor}" stroke="#fff" stroke-width="0.5" class="mtn-marker" data-name="${m.name}"/>`
      : `<polygon points="${m.x-sz},${m.y+sz*0.6} ${m.x+sz},${m.y+sz*0.6} ${m.x},${m.y-sz*1.2}" fill="${m.seriesColor}" opacity="0.85" stroke="rgba(255,255,255,0.5)" stroke-width="0.5" class="mtn-marker" data-name="${m.name}"/>`;
    html += shape;

    // 首山加星标
    if (m.isFirst) {
      html += `<text x="${m.x}" y="${m.y - sz*1.5 - 4}" text-anchor="middle" font-size="12" fill="#c9a037">★</text>`;
    }
  });

  // 名称标签 (偏移以避免重叠)
  allMountains.forEach((m, idx) => {
    // 标签位置 - 交替上下放置
    const offsetY = idx % 3 === 0 ? -20 : (idx % 3 === 1 ? -32 : 14);
    const offsetX = idx % 2 === 0 ? 0 : 0;
    const cls = m.isFirst ? 'mtn-label first-label' : 'mtn-label';
    html += `<text class="${cls}" x="${m.x + offsetX}" y="${m.y + offsetY}" text-anchor="middle" fill="${m.seriesColor}" data-name="${m.name}" style="font-size:${m.isFirst?'14':'12'}px">${m.name}</text>`;
  });

  // 资源图标 (在部分代表性山峰旁显示)
  allMountains.forEach(m => {
    let icons = '';
    if (m.minerals && m.minerals.length > 0) icons += '💎';
    if (m.plants && m.plants.length > 0) icons += '🌿';
    if (m.animals && m.animals.length > 0) icons += '🦊';
    if (m.rivers && m.rivers.length > 0) icons += '💧';
    if (icons.length > 0) {
      html += `<text class="resource-icon" x="${m.x + 12}" y="${m.y - 4}" font-size="10">${icons}</text>`;
    }
  });

  svg.innerHTML = html;

  // 绑定事件
  svg.querySelectorAll('.mtn-marker, .mtn-label, .first-label').forEach(el => {
    el.addEventListener('click', (e) => {
      const name = el.getAttribute('data-name');
      showDetail(name);
    });
    el.addEventListener('mouseenter', (e) => {
      const name = el.getAttribute('data-name');
      const m = allMountains.find(mt => mt.name === name);
      if (m) showTooltip(e, m);
    });
    el.addEventListener('mouseleave', () => {
      tooltip.style.display = 'none';
    });
  });
}

function showTooltip(e, m) {
  const rect = mapWrap.getBoundingClientRect();
  tooltip.innerHTML = `<b>${m.name}</b> <span style="color:#c9a96e">[${m.seriesName}]</span><br>${m.direction === '首' ? '首山' : m.direction + m.distance + '里'}<br>${m.text ? m.text.substring(0,60) + '…' : ''}`;
  tooltip.style.display = 'block';
  tooltip.style.left = (e.clientX - rect.left + 15) + 'px';
  tooltip.style.top = (e.clientY - rect.top - 30) + 'px';
}

function showDetail(name) {
  const m = allMountains.find(mt => mt.name === name);
  if (!m) return;
  currentMountain = m;

  let html = `<h2>${m.name}</h2>`;
  html += `<div style="color:#6b5a4a;font-size:12px;">${m.seriesName} | ${m.direction === '首' ? '首山' : '方向: ' + m.direction + ' · 距离: ' + m.distance + '里'} | 坐标: (${Math.round(m.x)}, ${Math.round(m.y)})里</div>`;

  if (m.text) {
    html += `<div class="section-title">📜 原文</div>`;
    html += `<div class="quote">${m.text}</div>`;
  }

  if (m.minerals && m.minerals.length > 0) {
    html += `<div class="section-title">💎 矿产</div><div class="tag-row">`;
    m.minerals.forEach(t => { html += `<span class="tag ${m.seriesId === 'nanshan1' ? 's1' : m.seriesId === 'nanshan2' ? 's2' : 's3'}">${t}</span>`; });
    html += `</div>`;
  }

  if (m.plants && m.plants.length > 0) {
    html += `<div class="section-title">🌿 植物</div>`;
    m.plants.forEach(p => { html += `<div style="margin:2px 0"><span class="tag ${m.seriesId === 'nanshan1' ? 's1' : m.seriesId === 'nanshan2' ? 's2' : 's3'}">${p.name}</span> ${p.desc}</div>`; });
  }

  if (m.animals && m.animals.length > 0) {
    html += `<div class="section-title">🦊 异兽</div>`;
    m.animals.forEach(a => { html += `<div style="margin:2px 0"><span class="tag ${m.seriesId === 'nanshan1' ? 's1' : m.seriesId === 'nanshan2' ? 's2' : 's3'}">${a.name}</span> ${a.desc}</div>`; });
  }

  if (m.rivers && m.rivers.length > 0) {
    html += `<div class="section-title">💧 水系</div>`;
    m.rivers.forEach(r => { html += `<div style="margin:2px 0"><span class="tag ${m.seriesId === 'nanshan1' ? 's1' : m.seriesId === 'nanshan2' ? 's2' : 's3'}">${r.name}</span> ${r.desc}</div>`; });
  }

  detailPanel.innerHTML = html;
}

// ============= 交互 =============
function applyZoom(z) {
  currentZoom = Math.max(0.05, Math.min(8, z));
  buildSVG(currentZoom);
  zoomLabel.textContent = Math.round(currentZoom * 100) + '%';
  updateScaleBar();
}

function zoomIn() { applyZoom(currentZoom * 1.25); }
function zoomOut() { applyZoom(currentZoom / 1.25); }
function zoomFit() {
  const wrapRect = mapWrap.getBoundingClientRect();
  const fitW = wrapRect.width / MAP_W;
  const fitH = wrapRect.height / MAP_H;
  applyZoom(Math.min(fitW, fitH) * 0.9);
}
function zoomReset() { applyZoom(1); }

function updateScaleBar() {
  // 在屏幕上显示约 500里 的实际像素
  const pixel500 = 500 * currentZoom;
  scaleBarBar.style.width = Math.min(pixel500, 200) + 'px';
  scaleBarLabel.textContent = pixel500 <= 200 ? '500里' : Math.round(500 * 200 / pixel500) + '里';
}

// 鼠标滚轮缩放
mapWrap.addEventListener('wheel', (e) => {
  e.preventDefault();
  const factor = e.deltaY < 0 ? 1.15 : 0.87;
  applyZoom(currentZoom * factor);
}, { passive: false });

// 坐标显示
mapWrap.addEventListener('mousemove', (e) => {
  const rect = mapWrap.getBoundingClientRect();
  const sx = (e.clientX - rect.left + mapWrap.scrollLeft) / currentZoom + minX;
  const sy = (e.clientY - rect.top + mapWrap.scrollTop) / currentZoom + minY;
  coordIndicator.textContent = `X: ${Math.round(sx)}里 | Y: ${Math.round(sy)}里`;
});

// 快捷键
document.addEventListener('keydown', (e) => {
  if (e.key === '+' || e.key === '=') { e.preventDefault(); zoomIn(); }
  if (e.key === '-') { e.preventDefault(); zoomOut(); }
  if (e.key === '0') { e.preventDefault(); zoomFit(); }
  if (e.key === '1') { e.preventDefault(); zoomReset(); }
});

