// ============================================================

const SCALE = 1; // 基础比例 1里 = 1px

// 方向到角度的映射 (弧度, 0=东/右, 顺时针)
const DIR_ANGLE = {
  '东': 0,
  '东南': Math.PI / 4,       // 45°
  '南': Math.PI / 2,         // 90°
  '西南': 3 * Math.PI / 4,   // 135°
  '西': Math.PI,             // 180°
  '西北': 5 * Math.PI / 4,   // 225°
  '北': 3 * Math.PI / 2,     // 270°
  '东北': 7 * Math.PI / 4,   // 315°
};

// 根据方向和距离计算 dx, dy (东为+x, 南为+y)
function dirToOffset(direction, distance) {
  const angle = DIR_ANGLE[direction];
  if (angle === undefined) return { dx: 0, dy: 0 };
  return {
    dx: Math.round(distance * Math.cos(angle) * 1000) / 1000,
    dy: Math.round(distance * Math.sin(angle) * 1000) / 1000,
  };
}

// 计算从首山开始的一系列山的绝对坐标
function computePositions(mountains) {
  let cx = 0, cy = 0;
  return mountains.map(m => {
    if (m.direction === '首') {
      cx = m.startX || 0;
      cy = m.startY || 0;
    } else {
      const off = dirToOffset(m.direction, m.distance);
      cx += off.dx;
      cy += off.dy;
    }
    return { ...m, x: Math.round(cx * 100) / 100, y: Math.round(cy * 100) / 100 };
  });
}

